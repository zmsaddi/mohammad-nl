{
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"]
    },
    "checkJs": false,
    "allowJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "esModuleInterop": true
  },
  "include": ["lib/**/*.js", "app/**/*.js", "components/**/*.js"],
  "exclude": ["node_modules", ".next", "scripts", "tests"]
}
